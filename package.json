{
  "name": "@shared/mcp-ts-engineer",
  "version": "1.0.0",
  "description": "Generic MCP server for multi-agent software engineering workflows. Import as git submodule into any monorepo.",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "rm -rf build && tsc",
    "start": "node build/bin.js",
    "dev": "tsx src/bin.ts",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --coverage",
    "postinstall": "bash scripts/patch-sdk-cache.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.45",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.17",
    "jest": "^29.7.0",
    "knip": "^5.83.0",
    "ts-jest": "^29.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  }
}
