{
  "name": "@shared/mcp-ts-engineer",
  "version": "1.0.0",
  "description": "Generic MCP server for multi-agent software engineering workflows. Import as git submodule into any monorepo.",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "rm -rf build && tsc -p tsconfig.build.json",
    "start": "node build/bin.js",
    "dev": "tsx src/bin.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "format": "biome check --write .",
    "format:check": "biome check --error-on-warnings .",
    "postinstall": "bash scripts/patch-sdk-cache.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "knip": "^5.83.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
